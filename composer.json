{
    "name": "pagarme/pagarme-magento2-module",
    "license": "MIT",
    "version": "2.8.1",
    "type": "magento2-module",
    "description": "Magento 2 Module Pagar.me",
    "minimum-stability": "dev",
    "require": {
        "php": ">=7.1",
        "pagarme/ecommerce-module-core": "dev-develop"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.7",
        "phpmd/phpmd": "@stable",
        "pdepend/pdepend": "^2.13",
        "friendsofphp/php-cs-fixer": "^3.0",
        "sebastian/phpcpd": "^6.0",
        "php-coveralls/php-coveralls": "^2.5",
        "magento-ecg/coding-standard": "dev-master",
        "rregeer/phpunit-coverage-check": "^0.1.3",
        "mockery/mockery": "^1.6.12"
    },
    "authors":[
        {
            "name":"Open Source Team"
        }
    ],
    "scripts": {
        "test": "phpunit"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Pagarme\\Pagarme\\": ""
        }
    },
    "config":{
        "secure-http":false
    }
}
